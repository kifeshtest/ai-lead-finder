# ── Server ──
PORT=4000
# Comma-separated allowed origins for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# ── Data source: mock | kvk | google ──
LEAD_SOURCE=mock

# ── Storage (leeg = in-memory, ephemeraal) ──
# DATABASE_URL=postgres://leadfinder:leadfinder@localhost:5432/leadfinder

# ── Queue (leeg = inline worker in-process; geen Redis nodig) ──
# REDIS_URL=redis://localhost:6379

# ── Lead-logica ──
SCORE_THRESHOLD=55
LEADS_PER_RUN=50
AUDIT_CONCURRENCY=5
MAX_SEARCH_ATTEMPTS=600

# ── Website-audit ──
# ENABLE_LIGHTHOUSE=false      # true vereist geïnstalleerde Chrome + optionalDependencies

# ── Auth (login) ──
ADMIN_USERNAME=jaimy
ADMIN_PASSWORD=verander-dit
JWT_SECRET=zet-hier-een-lange-willekeurige-string
# JWT_TTL_HOURS=12

# ── PageSpeed Insights (gratis key, GEEN creditcard nodig) ──
# PAGESPEED_API_KEY=
# ANALYSIS_ENABLED=true
# ANALYSIS_MAX_ATTEMPTS=3
# ANALYSIS_INTERVAL_MS=4000

# ── AI-motivatie (Anthropic Claude) ──
ENABLE_AI=false
# ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001

# ── Officiële bronnen (nodig voor LEAD_SOURCE=kvk / google) ──
# KVK_API_KEY=
KVK_API_BASE=https://api.kvk.nl/api/v2
# GOOGLE_PLACES_API_KEY=
# Max. Google Places-verzoeken per generatie (kostenrem)
MAX_PLACES_REQUESTS=40
